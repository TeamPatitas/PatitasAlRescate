<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="28dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/naranajBajo">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <ImageView
            android:id="@+id/img_foto_refugio"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_menu_gallery"
            android:scaleType="centerCrop"
            android:background="#E0E0E0"
            android:contentDescription="Foto del refugio"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/txt_nombre_refugio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            tools:text="Refugio Patitas"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#5D4037"
            app:layout_constraintStart_toEndOf="@id/img_foto_refugio"
            app:layout_constraintTop_toTopOf="@id/img_foto_refugio"
            app:layout_constraintEnd_toStartOf="@id/btn_whatsapp_refugio"/>

        <TextView
            android:id="@+id/txt_direccion_refugio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            tools:text="Dirección..."
            android:textColor="#757575"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="@id/txt_nombre_refugio"
            app:layout_constraintTop_toBottomOf="@id/txt_nombre_refugio"
            app:layout_constraintEnd_toStartOf="@id/btn_whatsapp_refugio"/>

        <ImageButton
            android:id="@+id/btn_whatsapp_refugio"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Contactar"
            android:src="@android:drawable/ic_menu_call"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_ver_mapa"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#25D366" />

        <ImageButton
            android:id="@+id/btn_ver_mapa"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Ver mapa"
            android:src="@android:drawable/ic_dialog_map"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#5D4037" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>