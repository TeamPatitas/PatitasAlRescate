<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    android:layout_marginHorizontal="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    android:backgroundTint="@color/naranajBajo">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/img_foto_evento"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_circle_image"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@tools:sample/backgrounds/scenic"/>

        <TextView
            android:id="@+id/txt_nombre_evento"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#5A3E2B"
            tools:text="Campaña de Adopción"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@id/img_foto_evento"
            app:layout_constraintTop_toTopOf="@id/img_foto_evento"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/txt_fecha_evento"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#6F6259"
            tools:text="15 de Octubre, 2023"
            app:layout_constraintStart_toStartOf="@id/txt_nombre_evento"
            app:layout_constraintTop_toBottomOf="@id/txt_nombre_evento"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/txt_descripcion_evento"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textStyle="italic"
            android:textColor="#7B4A36"
            tools:text="Ven y encuentra a tu mejor amigo en el parque central."
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="@id/txt_nombre_evento"
            app:layout_constraintTop_toBottomOf="@id/txt_fecha_evento"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btn_ver_evento"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Ver detalles"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/marronOscuro"
            app:layout_constraintTop_toBottomOf="@id/img_foto_evento"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>