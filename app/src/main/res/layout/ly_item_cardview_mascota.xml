<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="12dp"
    android:layout_marginHorizontal="8dp"
    app:cardCornerRadius="28dp"
    app:cardElevation="6dp"
    app:cardUseCompatPadding="true"
    android:backgroundTint="#ECE6E2">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="18dp">

        <!-- FOTO -->
        <ImageView
            android:id="@+id/img_foto_mascota"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_circle_image"
            android:clipToOutline="true"
            tools:src="@drawable/ic_launcher_foreground"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- NOMBRE -->
        <TextView
            android:id="@+id/txt_nombre_mascota"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#5A3E2B"
            tools:text="Max"
            app:layout_constraintStart_toEndOf="@id/img_foto_mascota"
            app:layout_constraintTop_toTopOf="@id/img_foto_mascota"
            app:layout_constraintEnd_toStartOf="@id/btn_detalles"
            android:layout_marginStart="16dp"/>

        <!-- EDAD -->
        <TextView
            android:id="@+id/txt_estado_mascota"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#6F6259"
            tools:text="2 años"
            app:layout_constraintStart_toStartOf="@id/txt_nombre_mascota"
            app:layout_constraintTop_toBottomOf="@id/txt_nombre_mascota"
            app:layout_constraintEnd_toStartOf="@id/btn_detalles"/>

        <!-- RAZA -->
        <TextView
            android:id="@+id/txt_raza_mascota"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#6F6259"
            tools:text="Golden Retriever"
            app:layout_constraintStart_toStartOf="@id/txt_nombre_mascota"
            app:layout_constraintTop_toBottomOf="@id/txt_estado_mascota"
            app:layout_constraintEnd_toStartOf="@id/btn_detalles"/>

        <!-- BOTÓN -->
        <Button
            android:id="@+id/btn_detalles"
            android:layout_width="150dp"
            android:layout_height="52dp"
            android:text="Ver Detalles"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_boton_detalles"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>


    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
