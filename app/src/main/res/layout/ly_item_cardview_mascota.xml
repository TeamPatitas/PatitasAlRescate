<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    android:layout_marginHorizontal="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    android:backgroundTint="@color/naranajBajo">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/img_foto_mascota"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_circle_image"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txt_nombre_mascota"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#5A3E2B"
            tools:text="Max"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@id/img_foto_mascota"
            app:layout_constraintTop_toTopOf="@id/img_foto_mascota"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/txt_raza_mascota"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#6F6259"
            tools:text="Raza"
            app:layout_constraintStart_toStartOf="@id/txt_nombre_mascota"
            app:layout_constraintTop_toBottomOf="@id/txt_nombre_mascota"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/txt_estado_mascota"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textStyle="italic"
            android:textColor="#7B4A36"
            tools:text="Disponible"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="@id/txt_nombre_mascota"
            app:layout_constraintTop_toBottomOf="@id/txt_raza_mascota"
            app:layout_constraintEnd_toEndOf="parent"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/img_foto_mascota"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Button
                android:id="@+id/btn_rechazar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="48dp"
                android:text="Rechazar"
                android:textSize="10sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#D32F2F"
                android:layout_marginEnd="4dp"
                android:visibility="gone"
                tools:visibility="visible"/>

            <Button
                android:id="@+id/btn_accion_rapida"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="48dp"
                android:text="Aprobar"
                android:textSize="10sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#8D6E63"
                android:layout_marginEnd="4dp"
                android:visibility="gone"
                tools:visibility="visible"/>

            <Button
                android:id="@+id/btn_principal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="48dp"
                android:text="Ver"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:backgroundTint="#5D4037"
                android:layout_marginStart="0dp"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>