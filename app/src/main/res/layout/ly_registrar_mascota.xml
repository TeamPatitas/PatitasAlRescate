<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/registrar_mascota_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8E1"
    tools:context=".Controllers.ActividadRegistrarMascota">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarRegistrarMascota"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#5D4037"
        app:title="Registra una Mascota"
        app:titleTextColor="@android:color/white"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarRegistrarMascota">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:gravity="center"
                android:text="Datos de la mascota"
                android:textStyle="bold"
                android:textColor="#3E2723"
                android:textSize="24sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="   Nombre de la mascota"
                app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                app:startIconTint="#5D4037">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txt_reg_nombre_mascota"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  Especie"
                android:textStyle="bold"
                android:textColor="#5D4037"
                android:gravity="center_vertical"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="8dp"
                android:drawableTint="#5D4037"
                android:layout_marginBottom="4dp"/>
            <Spinner
                android:id="@+id/spinner_especie"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@android:drawable/editbox_background"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/ly_otra_especie"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="   Escribe la especie"
                android:visibility="gone">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txt_otra_especie"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  Raza"
                android:textStyle="bold"
                android:textColor="#5D4037"
                android:gravity="center_vertical"
                android:drawableStart="@android:drawable/ic_menu_sort_by_size"
                android:drawablePadding="8dp"
                android:drawableTint="#5D4037"
                android:layout_marginBottom="4dp"/>
            <Spinner
                android:id="@+id/spinner_raza"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@android:drawable/editbox_background"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/ly_otra_raza"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="   Escribe la raza"
                android:visibility="gone">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txt_otra_raza"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  Sexo"
                android:textStyle="bold"
                android:textColor="#5D4037"
                android:gravity="center_vertical"
                android:drawableStart="@android:drawable/ic_menu_info_details"
                android:drawablePadding="8dp"
                android:drawableTint="#5D4037"
                android:layout_marginBottom="4dp"/>
            <Spinner
                android:id="@+id/spinner_sexo"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@android:drawable/editbox_background"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="   Edad (meses)"
                app:startIconDrawable="@android:drawable/ic_menu_day"
                app:startIconTint="#5D4037">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txt_reg_edad"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:maxLength="3" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="   Temperamento (ej. Juguetón)"
                app:startIconDrawable="@android:drawable/ic_menu_info_details"
                app:startIconTint="#5D4037">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txt_reg_temperamento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:hint="   Historia de rescate"
                app:startIconDrawable="@android:drawable/ic_menu_edit"
                app:startIconTint="#5D4037">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/txt_reg_historia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:lines="5"
                    android:gravity="top" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btn_seleccionar_fotos"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Seleccionar Fotos"
                android:textColor="#388E3C"
                app:strokeColor="#388E3C"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_fotos_preview"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <Button
                android:id="@+id/btn_guardar_mascota"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:backgroundTint="#FF9800"
                android:text="REGISTRAR MASCOTA"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                app:cornerRadius="30dp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>