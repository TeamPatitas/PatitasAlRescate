<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EFEBE9"
    tools:context=".Controllers.ActividadListarRefugios">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarListarRefugios"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#5D4037"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:title="Nuestros Refugios"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_refugios"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/toolbarListarRefugios"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/ly_item_cardview_refugio" />

    <TextView
        android:id="@+id/txt_refugios_vacio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No hay refugios registrados 🐾"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>