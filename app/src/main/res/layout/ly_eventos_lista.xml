<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/listar_eventos"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EFEBE9">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarListarEventos"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/marronOscuro"
        android:theme="?attr/actionBarTheme"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:title="Eventos"
        app:titleTextColor="@android:color/white" />

    <TextView
        android:id="@+id/txt_lista_eventos_vacia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No se encontraron eventos 🐾"
        android:textColor="@color/textoSecundario"
        android:textSize="18sp"
        android:textStyle="italic"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarListarEventos" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_eventos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarListarEventos"
        tools:listitem="@layout/ly_eventos_element" />

</androidx.constraintlayout.widget.ConstraintLayout>