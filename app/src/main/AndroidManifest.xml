<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_icono"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_icono_round"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.PatitasAlRescate">
        <activity
            android:name=".MainActivity"
            android:exported="true" >
        <intent-filter>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
        </activity>

        <activity
            android:name=".controllers.management.ActividadRegistrarMascota"
            android:exported="false"
            android:parentActivityName=".controllers.feed.ActividadInicioRefugio"/>
        <activity
            android:name=".controllers.management.ActividadAdopcion"
            android:exported="false" />
        <activity
            android:name=".controllers.management.ActividadPerfilMascota"
            android:exported="false" />
        <activity
            android:name=".controllers.lists.ActividadListarRefugios"
            android:exported="false" />
        <activity
            android:name=".controllers.lists.ActividadBusquedaPorFiltro"
            android:exported="false" />
        <activity
            android:name=".controllers.lists.ActividadMisFavoritos"
            android:exported="false" />
        <activity
            android:name=".controllers.lists.ActividadListarMascotas"
            android:exported = "false"/>
        <activity
            android:name=".controllers.feed.ActividadRegistroExitoso"
            android:exported="false" />
        <activity
            android:name=".controllers.feed.ActividadInicioAdoptante"
            android:exported="false" />
        <activity
            android:name=".controllers.auth.ActividadRegistrarAdoptante"
            android:exported="false" />
        <activity
            android:name=".controllers.auth.ActividadRegistrarOrganizacion"
            android:exported="false"
            android:parentActivityName=".controllers.auth.ActividadIngresar"/>

        <activity
            android:name=".controllers.auth.ActividadIniciarSesion"
            android:exported="false" />
        <activity
            android:name=".controllers.auth.ActividadIngresar"
            android:exported="false"
            android:theme="@style/Theme.PatitasAlRescate" />
        <activity
            android:name=".controllers.feed.ActividadInicioRefugio"
            android:exported="false"
            android:parentActivityName=".controllers.auth.ActividadIniciarSesion" />

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />
    </application>

</manifest>